# คัดลอกเป็น .env แล้วใส่ค่าจริง (.env ถูก gitignore) — บน Render ใส่ใน Environment Variables แทน

# เว้นว่าง = SQLite local (mms.db) | จะใช้ Postgres ก็ใส่ connection string ได้
MMS_DB_URL=

# รหัสบัญชีเจ้าของร้าน (user: owner) — ตั้งใหม่ใน prod เสมอ
MMS_OWNER_PASS=change-this-strong-password

# JWT secret — สุ่มยาวๆ
MMS_SECRET_KEY=random-long-secret
